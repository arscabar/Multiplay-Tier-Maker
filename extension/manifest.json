{
  "manifest_version": 3,
  "name": "Multiplay Tier Maker Apply Tool",
  "version": "1.0.0",
  "description": "TierMaker create pages에서 Multiplay Tier Maker로 현재 템플릿을 보내는 플로팅 메뉴입니다.",
  "permissions": ["storage"],
  "host_permissions": [
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*",
    "https://*.trycloudflare.com/*",
    "https://*.onrender.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://tiermaker.com/create/*", "https://www.tiermaker.com/create/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
