{
  "name": "multiplay-tier-maker",
  "version": "1.1.6",
  "description": "Realtime multiplay TierMaker room builder.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "tunnel": "powershell -ExecutionPolicy Bypass -File scripts/start-tunnel.ps1",
    "cloudflared:install": "powershell -ExecutionPolicy Bypass -File scripts/install-cloudflared.ps1",
    "smoke:templates": "node scripts/smoke-templates.js",
    "smoke:worldcup": "node scripts/smoke-worldcup.js",
    "build:launcher": "powershell -ExecutionPolicy Bypass -File scripts/build-launcher.ps1",
    "check": "node --check server.js && node --check public/app.js && node --check scripts/smoke-templates.js && node --check scripts/smoke-worldcup.js && node --check extension/content.js && node -e \"JSON.parse(require('fs').readFileSync('extension/manifest.json','utf8'))\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "express": "^5.2.1",
    "lucide": "^1.21.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "socket.io-client": "^4.8.3"
  }
}
